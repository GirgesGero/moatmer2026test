  "lectures": [
    {
      "id": "d1-l1",
      "day": 1,
      "title": "المحاضرة الأولى (اليوم الأول)",
      "speaker": "سيتم تحديده لاحقاً",
      "time": "13:00 - 15:00",
      "place": "القاعة الرئيسية",
      "summary": "المحاضرة الافتتاحية للمؤتمر. سيتم إضافة تفاصيل المحتوى وأهداف المحاضرة قريباً.",
      "goals": [
        "التعرف على فكرة المؤتمر الأساسية",
        "المشاركة والتفاعل البناء"
      ],
      "keyTakeaways": [
        "المحور الأول للمحاضرة",
        "التطبيقات والنتائج المنتظرة"
      ],
      "notesEnabled": true
    },
    {
      "id": "d2-l1",
      "day": 2,
      "title": "المحاضرة الثانية (اليوم الثاني)",
      "speaker": "سيتم تحديده لاحقاً",
      "time": "14:00 - 16:00",
      "place": "القاعة الرئيسية",
      "summary": "المحاضرة الروحية الرئيسية لليوم الثاني من المؤتمر.",
      "goals": [
        "فهم العمق الروحي لشعار المؤتمر",
        "تطبيق المفاهيم في الحياة العملية"
      ],
      "keyTakeaways": [
        "النقاط الإرشادية لليوم الثاني",
        "خطوات عملية للنمو الروحي"
      ],
      "notesEnabled": true
    },
    {
      "id": "d3-l1",
      "day": 3,
      "title": "المحاضرة الثالثة (اليوم الثالث)",
      "speaker": "سيتم تحديده لاحقاً",
      "time": "18:00 - 20:00",
      "place": "القاعة الرئيسية",
      "summary": "محاضرة الختام والتقييم الروحي للمؤتمر وتلخيص أهم الدروس المستفادة.",
      "goals": [
        "مراجعة ما تم تحصيله في الأيام الثلاثة",
        "الالتزام بالتطبيقات المستقبلية"
      ],
      "keyTakeaways": [
        "الرسالة الختامية للمؤتمر",
        "الخطوات القادمة بعد العودة"
      ],
      "notesEnabled": true
    }
  ],
  "workshops": [
    {
      "id": "d1-w1",
      "day": 1,
      "title": "فك الشفرة: من يقود فكرك؟ 🧠",
      "speaker": "فريق الورش والتدريب",
      "time": "7:00 pm - 9:00 pm",
      "place": "قاعة ورش العمل",
      "summary": "هل فكرت يوماً من أين تأتي قناعاتك؟ في هذه الورشة التفاعلية سنكشف الستار عن المؤثرات الخفية التي تشكل عقولنا وتصنع قراراتنا اليومية.",
      "practicalApplication": "تحدي 'فرز الأصوات': تمرين تفاعلي للتمييز بين ضجيج السوشيال ميديا وصوت الضمير الهادئ، وفرز القناعات المنتشرة لاكتشاف الحقيقة.",
      "skillsGained": [
        "كشف المصادر المؤثرة على فكر الشباب",
        "التمييز بين صوت المجتمع وصوت الله",
        "كسر وهم الانتشار (ليس كل ما هو شائع صحيح)"
      ]
    },
    {
      "id": "d2-w1",
      "day": 2,
      "title": "البوصلة والذكاء الاصطناعي: من القائد؟ 🧭🤖",
      "speaker": "فريق الورش والتدريب",
      "time": "7:00 pm - 9:00 pm",
      "place": "قاعة ورش العمل",
      "summary": "رحلة استكشافية مثيرة داخل أعماقك لاكتشاف المحرك الحقيقي لحياتك، وكيف تكون قائداً مؤثراً في عصر التكنولوجيا والذكاء الاصطناعي دون أن تفقد هويتك.",
      "practicalApplication": "محاكاة 'القيادة الذكية': مواقف حية لمواجهة التضليل التكنولوجي، وتمثيل أدوار للفرق بين القائد والمسيطر في الحياة اليومية.",
      "skillsGained": [
        "اكتشاف المحرك الحقيقي لحياتي وما يقودها",
        "فهم الفروق الجوهرية بين القيادي والمسيطر",
        "التعامل الصحيح والواعي مع التكنولوجيا والذكاء الاصطناعي (AI)"
      ]
    },
    {
      "id": "d3-w1",
      "day": 3,
      "title": "خريطة الطريق والشخصيات السبعة 🗺️👤",
      "speaker": "فريق الورش والتدريب",
      "time": "2:00 pm - 4:00 pm",
      "place": "قاعة ورش العمل",
      "summary": "في نهاية الرحلة، نضع بين يديك المعايير الذهبية لمعرفة مدى صحة مسارك اليومي، ونكشف أسرار الأنماط السبعة للشخصيات وكيفية التعامل معها بذكاء ونضج.",
      "practicalApplication": "اختبار 'الشخصيات السبعة': تمرين ممتع لاكتشاف نمط شخصيتك وتحديد خطوات عملية للتأكد من السير في الطريق الصحيح.",
      "skillsGained": [
        "معايير قياس وتصحيح الاتجاه (إزاي أعرف إني ماشي صح؟)",
        "فهم وتحليل الشخصيات السبعة والتعامل معها",
        "رسم خطة نمو شخصية وروحية متكاملة"
      ]
    }
  ],
